{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Engagement Plan",
  "type": "object",
  "required": [
    "iteration_id",
    "goal_title",
    "classification",
    "impact",
    "selected_agents"
  ],
  "properties": {
    "iteration_id": {
      "type": "string"
    },
    "goal_title": {
      "type": "string"
    },
    "classification": {
      "type": "object",
      "required": [
        "primary_type"
      ],
      "properties": {
        "primary_type": {
          "type": "string"
        },
        "secondary_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "impact": {
      "type": "object",
      "properties": {
        "product_scope": {
          "$ref": "#/$defs/impact_level"
        },
        "requirements": {
          "$ref": "#/$defs/impact_level"
        },
        "architecture": {
          "$ref": "#/$defs/impact_level"
        },
        "data_contract": {
          "$ref": "#/$defs/impact_level"
        },
        "ui_ux": {
          "$ref": "#/$defs/impact_level"
        },
        "implementation": {
          "$ref": "#/$defs/impact_level"
        },
        "testing": {
          "$ref": "#/$defs/impact_level"
        },
        "security": {
          "$ref": "#/$defs/impact_level"
        },
        "release": {
          "$ref": "#/$defs/impact_level"
        },
        "documentation": {
          "$ref": "#/$defs/impact_level"
        }
      }
    },
    "selected_agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "agent",
          "role",
          "execution_mode",
          "reason"
        ],
        "properties": {
          "agent": {
            "type": "string"
          },
          "role": {
            "enum": [
              "owner",
              "reviewer",
              "consultant",
              "gatekeeper"
            ]
          },
          "execution_mode": {
            "$ref": "#/$defs/execution_mode"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "human_decision_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "impact_level": {
      "enum": [
        "none",
        "low",
        "medium",
        "high"
      ]
    },
    "execution_mode": {
      "enum": [
        "inline",
        "isolated_task",
        "isolated_worktree",
        "independent_review",
        "human_decision"
      ]
    }
  },
  "additionalProperties": true
}
